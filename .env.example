# ===================================
# Anwesenheit-NEO-onprem .env Beispiel
# ===================================

# Server
PORT=3000
NODE_ENV=production

# Datenbank (SQLite Standard)
DATABASE_URL="file:./data/anwesenheit.db"
# PostgreSQL Alternative:
# DATABASE_URL="postgresql://user:password@localhost:5432/anwesenheit"

# JWT – UNBEDINGT ÄNDERN!
JWT_SECRET=AENDERN_SEHR_LANGER_GEHEIMER_SCHLUESSEL_MINDESTENS_32_ZEICHEN
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# App
APP_TITLE="Anwesenheit NEO"
APP_URL=http://localhost:3000

# Backups
BACKUP_DIR=./backups
BACKUP_CRON="0 2 * * *"
BACKUP_RETENTION_DAYS=30

# Cronjob-Zeitpläne (optional überschreiben)
# CRON_AUTO_CANCEL="*/5 * * * *"
# CRON_CLEANUP_CODES="0 3 * * *"
# CRON_REMINDERS="0 * * * *"
